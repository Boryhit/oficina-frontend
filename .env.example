# ========================================
# Configurações de ambiente – EXEMPLO
# Copie este arquivo para `.env` (ou `.env.local`) e ajuste os valores.
# NUNCA versionar o `.env` real no Git.
# ========================================

# URL base da sua API REST (backend)
# Em desenvolvimento local geralmente é http://localhost:3000
# Em produção use a URL pública, ex.: https://api.suaoficina.com
VITE_API_URL=http://localhost:3000

# (Opcional) Timeout padrão das requisições em ms
VITE_API_TIMEOUT=15000

# (Opcional) Ambiente atual – útil para logs/telemetria
VITE_APP_ENV=development
